# Fleet dev environment — loaded by ./dev.sh. Committable: no secrets here
# (secrets belong in .env.local, which is gitignored).

# Origin the fleet-client server reverse-proxies /bridge/* to. Must match the
# port in fleet-bridge-config.yaml. The browser's Eden treaty talks to the
# same-origin /bridge prefix, which forwards here.
BRIDGE_URL=http://localhost:4800
