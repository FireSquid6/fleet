{
  "name": "fleet-bridge",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./api": "./src/api/index.ts"
  },
  "bin": {
    "fleet-bridge": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests",
    "db:generate": "drizzle-kit generate --config drizzle-configs/dev.config.ts"
  },
  "dependencies": {
    "@elysiajs/eden": "latest",
    "commander": "latest",
    "drizzle": "^1.4.0",
    "drizzle-orm": "^0.45.2",
    "elysia": "latest",
    "fleet-protocol": "workspace:*",
    "fleet-ship": "workspace:*",
    "yaml": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
